# ==========================================
# DentFlow SaaS - Environment Variables
# ==========================================

# ------------------------------------------
# BACKEND (Render)
# ------------------------------------------
PORT=5000
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# Security / Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# CORS Configuration
# Set this to your Vercel frontend URL in production (e.g., https://dentflow.vercel.app)
CORS_ORIGIN=*

# ------------------------------------------
# FRONTEND (Vercel)
# ------------------------------------------
# API URL must point to your Render backend in production
VITE_API_URL=http://localhost:5000/api
