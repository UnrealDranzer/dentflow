# ==========================================
# DentFlow SaaS - Backend Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to Git.

# ------------------------------------------
# REQUIRED for production
# ------------------------------------------

# Neon PostgreSQL connection string
# Get from: Neon Dashboard → Project → Connection Details → Connection String
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# JWT secret — use a strong random string (64+ chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — set to your Vercel frontend URL in production
# Example: https://dentflow.vercel.app
CORS_ORIGIN=*

# ------------------------------------------
# OPTIONAL integrations (not required to run)
# ------------------------------------------

# SMS (MSG91)
# SMS_API_KEY=your_msg91_api_key
# SMS_SENDER_ID=DENTFL

# Email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
